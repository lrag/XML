	<complexType name="pelicula">
		<sequence>
			<element name="titulo"   type="string" />
			<element name="director" type="string" />
			<element name="genero"   type="string" />
			<element name="year"     type="integer" />
		</sequence>
		<attribute name="id" use="required" type="integer"/>
	</complexType>

	<element name="peliculas">
		<complexType>
			<sequence>
				<element name="pelicula" minOccurs="0" maxOccurs="unbounded" type="tns:pelicula"/>
			</sequence>
		</complexType>
	</element>	
		
</schema>










