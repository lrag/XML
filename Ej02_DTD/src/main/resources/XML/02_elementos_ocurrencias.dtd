<!--

Elementos con hijos (secuencias)

Una ocurrencia OBLIGATORIA

	<!ELEMENT element-name (hijo)>
	
	<!ELEMENT pelicula (titulo)>
	
	<pelicula>  <- ERROR, es obligatorio
	</pelicula>
	
	<pelicula> <!- OK
		<titulo>2001</titulo>
	</pelicula>
	
	<pelicula> <- ERROR, debe haber solo una
		<titulo>2001</titulo>
		<titulo>ERROR!</titulo>
	</pelicula>
	
Mínimo una ocurrencia		

	<!ELEMENT element-name (hijo+)
		
	<!ELEMENT pelicula (genero+)
	<!ELEMENT genero (#PCDATA)>
	
	<pelicula> <- ERROR
		ERROR!	
	</pelicula>	
	<pelicula> <- OK
		<genero>Ciencia ficción</genero>	
	</pelicula>
	<pelicula> <- OK
		<genero>Ciencia ficción</genero>	
		<genero>Terror</genero>
	</pelicula>
	
Cero o más ocurrencias

	<!ELEMENT element-name (hijo*)
		
	<!ELEMENT pedido (incidencia*)
	<!ELEMENT incidencia (#PCDATA)>
	
	<pedido> <- OK	
	</pedido>	
	<pedido> <- OK
		<incidencia>Falta un producto</incidencia>	
	</pedido>		
	<pedido> <- OK
		<incidencia>Falta un producto</incidencia>	
		<incidencia>Direccion incorrecta</incidencia>
	</pedido>		

Cero o una ocurrencia

	<!ELEMENT element-name (hijo?)
		
	<!ELEMENT persona (dni?)
	<!ELEMENT dni (#PCDATA)>
	
	<persona> <- OK	
	</persona>	
	<persona> <- OK
		<dni>12345</dni>	
	</persona>	
	<persona> <- ERROR
		<dni>12345</dni>	
		<dni>54321</dni>	
	</persona>	
	
Contenido variable

	<!ELEMENT etiqueta1 (etiqueta2|etiqueta3)>
	<!ELEMENT etiqueta2 (#PCDATA)>
	<!ELEMENT etiqueta3 (#PCDATA)>
	
	<etiqueta1>
		<etiqueta2>aaa</etiqueta2>
	</etiqueta1>
	<etiqueta1>
		<etiqueta3>bbb</etiqueta3>
	</etiqueta1>
	
	<!ELEMENT correo (to,from,(texto|body))>	
	
	<correo> <- Error: tiene que tener texto ó body
		<to>Venancia</to>
		<from>Venancio</from>
	</correo>
	<correo> <- OK
		<to>Venancia</to>
		<from>Venancio</from>
		<texto>OLA KE TAL</texto>
	</correo>
	<correo> <- OK
		<to>Venancia</to>
		<from>Venancio</from>
		<body>OLA KE TAL</body>
	</correo>
	
	<!ELEMENT table (tableHead?, (tr+|tableBody))>
	<!ELEMENT tableHead (tr*)>
	<!ELEMENT tableBody (tr*)>
	<!ELEMENT tr ( (td+|th+) )>
	<!ELEMENT td ANY>
	<!ELEMENT th ANY>
	
	<table>
		<tr></tr>
	</table>
	<table>
		<tableHead></tableBody>
		<tr></tr>
	</table>
	<table>
		<tableHead></tableBody>
		<tableBody></tableBody>
	</table>	
	
	<!ELEMENT table (tableHead?, (tr*|tableBody))>
	<!ELEMENT documento (capitulo|nota)*>
-->

